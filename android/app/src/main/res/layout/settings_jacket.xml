<?xml version="1.0" encoding="utf-8"?>
<quarky.com.br.mercuryjacket.ui.layout.SettingsLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:id="@+id/title_bt"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:paddingHorizontal="25dp"
        android:orientation="horizontal">

        <quarky.com.br.mercuryjacket.ui.view.CustomTextView
            android:id="@+id/name_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:text="Device name"
            android:textColor="@color/white"
            android:textSize="@dimen/titleSize"
            app:fontFamily="@string/regular_font"/>

        <RelativeLayout
            android:id="@+id/arrow"
            android:layout_width="@dimen/arrowIconWidth"
            android:layout_height="@dimen/arrowIconHeight"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:background="@drawable/ic_arrow_up"></RelativeLayout>

    </RelativeLayout>

    <include
        layout="@layout/divide_dark"
        android:layout_width="wrap_content"
        android:layout_height="1dp" />


    <LinearLayout
        android:id="@+id/options"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:animateLayoutChanges="true"
        android:orientation="vertical"
        android:paddingTop="15dp"
        android:visibility="visible"
        android:weightSum="100">

        <!--<include layout="@layout/setting_line" />-->

        <!--<include layout="@layout/setting_line" app:title="@{@string/settings_title}" />-->

        <!--<include layout="@layout/setting_line" />-->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="15dp"
            android:layout_marginTop="25dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="25dp"
            android:weightSum="100">

            <include
                android:id="@+id/bt_disconnect"
                layout="@layout/connect_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp" />

            <include
                android:id="@+id/bt_delete"
                layout="@layout/delete_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp" />

            <include
                android:id="@+id/bt_connect"
                layout="@layout/connect_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>

<!--        <include-->
<!--            layout="@layout/divide_dark"-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="1dp"-->
<!--            android:layout_marginTop="15dp"/>-->

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/dotted"
            android:layerType="software" />

    </LinearLayout>

</quarky.com.br.mercuryjacket.ui.layout.SettingsLayout>
