<?xml version="1.0" encoding="utf-8"?>
<quarky.com.br.mercuryjacket.ui.layout.ActionBarLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <quarky.com.br.mercuryjacket.ui.view.CustomTextView
        android:id="@+id/jacket_name_txt"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_marginLeft="5dp"
        android:gravity="center_vertical"
        android:text="Mercury App"
        android:textColor="@color/white"
        android:textSize="@dimen/titleSize"
        app:fontFamily="@string/regular_font" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_alignParentRight="true"
        android:layout_marginRight="5dp"
        android:gravity="center_vertical|right"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/temperature_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="25dp"
            android:gravity="bottom"
            android:orientation="horizontal">
            <quarky.com.br.mercuryjacket.ui.view.CustomTextView
                android:id="@+id/temperature_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="4dp"
                android:text="--"
                android:textColor="@color/white"
                android:textSize="@dimen/titleSize"
                app:fontFamily="@string/regular_font" />

            <quarky.com.br.mercuryjacket.ui.view.CustomTextView
                android:id="@+id/measure_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/greyThree"
                android:textSize="16sp"
                app:fontFamily="@string/regular_font" />

            <ImageView
                android:id="@+id/location_icon"
                android:layout_width="wrap_content"
                android:layout_height="18dp"
                android:adjustViewBounds="true"
                android:layout_marginBottom="2dp"
                android:layout_marginLeft="4dp"
                android:src="@drawable/ic_jacket" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/settings_bt"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:weightSum="100">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="30"
                android:adjustViewBounds="true"
                android:src="@drawable/config_bt" />
        </LinearLayout>
    </LinearLayout>

</quarky.com.br.mercuryjacket.ui.layout.ActionBarLayout>