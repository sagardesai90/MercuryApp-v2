<?xml version="1.0" encoding="utf-8"?>
<quarky.com.br.mercuryjacket.ui.layout.TemperatureSliderLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/temperature_slider"
    android:layout_width="wrap_content"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:adjustViewBounds="true"
        android:src="@drawable/bg_temperature_controller"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="bottom"
        android:orientation="horizontal"
        android:weightSum="100">

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2.5" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="95"
            android:gravity="bottom"
            android:orientation="vertical"
            android:weightSum="100">

            <quarky.com.br.mercuryjacket.ui.layout.RoundedClipLayout
                android:id="@+id/bar"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0"
                android:clipChildren="true">

                <ImageView
                    android:id="@+id/bar_image"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:adjustViewBounds="true"
                    android:src="@drawable/bar_temperature_controller"
                    android:tint="@color/green1"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="H,1:2.134615" />
            </quarky.com.br.mercuryjacket.ui.layout.RoundedClipLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1.15" />

        </LinearLayout>

    </LinearLayout>
</quarky.com.br.mercuryjacket.ui.layout.TemperatureSliderLayout>