<?xml version="1.0" encoding="utf-8"?>
<quarky.com.br.mercuryjacket.ui.layout.SettingLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:weightSum="100"
    android:paddingTop="15dp"
    android:paddingBottom="15dp"
    android:paddingHorizontal="25dp">

    <quarky.com.br.mercuryjacket.ui.view.CustomTextView
        android:id="@+id/title_txt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:layout_weight="70"
        android:text="Automatically turn your Mercury garment on when motion is detected"
        android:textColor="@color/greyThree"
        android:textSize="19sp"
        app:fontFamily="@string/regular_font" />

    <View
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="5" />

    <RelativeLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_weight="25"
        android:paddingTop="5dp">
        
        <include
            android:id="@+id/switch_bt"
            layout="@layout/switch_button" />

    </RelativeLayout>

</quarky.com.br.mercuryjacket.ui.layout.SettingLayout>