<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="10dp"
    android:background="@drawable/rounded_background_dark"
    android:fillViewport="true"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/titleHeight"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/titleHPadding"
            android:paddingVertical="@dimen/titleVPadding">

            <ImageView
                android:id="@+id/close_bt"
                android:layout_width="@dimen/infoIconWidth"
                android:layout_height="@dimen/infoIconHeight"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:src="@drawable/x" />

        </RelativeLayout>

        <include layout="@layout/divide_clean" />
    </LinearLayout>

    <quarky.com.br.mercuryjacket.ui.view.CustomTextView
        android:id="@+id/debug_txt"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="30dp"
        android:layout_marginLeft="28dp"
        android:layout_marginRight="28dp"
        android:layout_marginTop="40dp"
        android:textAlignment="textStart"
        android:textColor="@color/white"
        android:textSize="@dimen/titleSize"
        app:fontFamily="@string/regular_font"
        android:scrollbars="vertical"
        android:maxLines="25"/>

</LinearLayout>