<resources>

    <style name="NoActionBarTheme" parent="android:Theme.Material.Light.DarkActionBar">
        <!--<item first_name="android:launchMode">singleInstance</item>-->
        <item name="android:launchMode">singleTop</item>

        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowSoftInputMode">stateHidden</item>
        <!--<item name="android:actionBarStyle">@style/ActionBar</item>-->
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:fitsSystemWindows">true</item>
        <item name="android:colorPrimaryDark">@color/black</item>

        <item name="android:windowActionBarOverlay">true</item>
        <item name="android:actionBarDivider">@android:color/transparent</item>
        <!--<item first_name="android:windowBackground">@android:color/transparent</item>-->
        <item name="android:windowBackground">@color/black</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="android:Theme.Material.Light.DarkActionBar">
        <!--<item first_name="android:launchMode">singleInstance</item>-->
        <item name="android:launchMode">singleTop</item>

        <item name="android:windowSoftInputMode">adjustPan</item>
        <!--<item name="android:actionBarStyle">@style/ActionBar</item>-->
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:fitsSystemWindows">true</item>
        <item name="android:colorPrimaryDark">@color/darkgrey</item>

        <item name="android:windowActionBarOverlay">true</item>
        <item name="android:actionBarDivider">@android:color/transparent</item>
        <item name="android:windowBackground">@color/black</item>
        <!--<item first_name="android:windowBackground">@android:color/transparent</item>-->
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowContentOverlay">@null</item>
        <!--<item name="android:actionBarSize">55dp</item>-->
    </style>

    <!--<style name="ActionBar">-->
        <!--<item name="android:contentInsetEnd">0dp</item>-->
        <!--<item name="android:contentInsetStart">0dp</item>-->
        <!--<item name="android:contentInsetLeft">0dp</item>-->
        <!--<item name="android:contentInsetRight">0dp</item>-->
    <!--</style>-->

    <style name="NewDialog" parent="@android:style/Theme.Dialog">
        <item name="android:windowFrame">@null</item>
        <item name="android:windowBackground">@color/black_70</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowTitleStyle">@null</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Dialog</item>
        <item name="android:windowSoftInputMode">stateUnspecified|adjustPan</item>
        <item name="android:layout_gravity">center</item>
    </style>

    <style name="JacketDialog" parent="NewDialog">
        <item name="android:windowSoftInputMode">adjustResize|stateHidden</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

</resources>
